---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Academic Door Journals",
  description = "经济学期刊监测、中文目录与 Academic Door Composer",
} = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#173f35" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>
        <span class="brand-mark">AD</span>
        <span>
          <strong>Academic Door</strong>
          <small>Journals</small>
        </span>
      </a>
      <nav aria-label="主导航">
        <a href={`${base}top5/`}>TOP5</a>
        <a href={`${base}composer/`}>Composer</a>
        <a href={`${base}status/`}>状态</a>
        <a href="https://academic-door.github.io/">品牌主页</a>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">
      <p>Academic Door / 学术传送门 · 面向中文读者的开放学术信息服务</p>
      <p>论文信息与版权以期刊官网和论文原文为准。</p>
    </footer>
  </body>
</html>
