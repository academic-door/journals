---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Academic Door Journals",
  description = "经济学期刊监测、中文目录与 Academic Door Composer",
} = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b2f28" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>
        <span>
          <strong>Academic Door</strong>
          <small>Journals</small>
        </span>
      </a>
      <nav aria-label="主导航">
        <a href={base}>TOP5</a>
        <a href={`${base}fields/`}>Field Journals</a>
        <a href={`${base}composer/`}>Composer</a>
        <a href="https://academic-door.github.io/">Academic Door</a>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">
      <p>Academic Door / 学术传送门 · 读好文献，用好论文。</p>
      <p>
        <a href={`${base}status/`}>数据状态</a>
        <span aria-hidden="true"> · </span>
        论文信息与版权以期刊官网和原文为准
      </p>
    </footer>
  </body>
</html>
